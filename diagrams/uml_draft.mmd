classDiagram
    class Owner {
        +string name
        +int available_time_per_day
        +list preferences
        +add_preference()
        +update_available_time()
        +get_preferences()
    }

    class Pet {
        +string name
        +string species
        +int age
        +list health_notes
        +list care_needs
        +update_profile()
        +add_care_need()
        +get_care_summary()
    }

    class CareTask {
        +string title
        +string type
        +int duration_minutes
        +string priority
        +string preferred_time
        +bool recurring
        +update_task()
        +mark_complete()
        +get_priority_score()
    }

    class Scheduler {
        +list tasks
        +dict owner_constraints
        +Pet pet_profile
        +int available_time
        +sort_tasks()
        +filter_tasks()
        +build_daily_plan()
        +resolve_conflicts()
    }

    class DailyPlan {
        +string date
        +list scheduled_tasks
        +int total_time_used
        +list explanation_notes
        +add_task()
        +remove_task()
        +generate_explanation()
        +display_plan()
    }

    Owner "1" --> "1..*" Pet : has pets
    Pet "1" --> "0..*" CareTask : has tasks
    Scheduler --> Owner : uses owner info
    Scheduler --> Pet : plans for
    Scheduler --> DailyPlan : creates
